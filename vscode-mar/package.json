{
  "name": "mar-language-support",
  "displayName": "mar",
  "description": "Language support for the mar programming language",
  "version": "0.0.6",
  "publisher": "mar-lang",
  "repository": {
    "type": "git",
    "url": "https://github.com/marlanghq/mar-lang"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:mar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "mar",
        "aliases": [
          "mar",
          "Mar"
        ],
        "extensions": [
          ".mar"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "mar",
        "scopeName": "source.mar",
        "path": "./syntaxes/mar.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "mar",
      "properties": {
        "mar.serverPath": {
          "type": "string",
          "default": "mar",
          "description": "Path to the mar binary used to launch the language server. Override if `mar` isn't on your $PATH."
        }
      }
    }
  },
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --minify",
    "watch": "esbuild ./src/extension.ts --bundle --outfile=out/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap --watch",
    "compile": "npm run typecheck && npm run bundle",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.25.12",
    "typescript": "^6.0.3"
  }
}
