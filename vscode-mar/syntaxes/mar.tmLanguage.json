{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mar",
  "scopeName": "source.mar",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.mar",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mar",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.mar"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.mar"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.mar",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.app.declaration.mar",
          "match": "\\b(app)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.mar"
            },
            "2": {
              "name": "entity.name.type.mar"
            }
          }
        },
        {
          "name": "meta.entity.declaration.mar",
          "match": "\\b(entity)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.mar"
            },
            "2": {
              "name": "entity.name.type.mar"
            }
          }
        },
        {
          "name": "meta.public.declaration.mar",
          "match": "\\b(public)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.mar"
            },
            "2": {
              "name": "punctuation.section.block.begin.mar"
            }
          }
        },
        {
          "name": "meta.system.declaration.mar",
          "match": "\\b(system)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.mar"
            },
            "2": {
              "name": "punctuation.section.block.begin.mar"
            }
          }
        },
        {
          "name": "meta.typealias.declaration.mar",
          "match": "\\b(type)\\s+(alias)\\s+([A-Z][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.mar"
            },
            "2": {
              "name": "keyword.control.declaration.mar"
            },
            "3": {
              "name": "entity.name.type.mar"
            },
            "4": {
              "name": "keyword.operator.assignment.mar"
            }
          }
        },
        {
          "name": "meta.action.declaration.mar",
          "match": "\\b(action)\\s+([a-z][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.mar"
            },
            "2": {
              "name": "entity.name.function.mar"
            },
            "3": {
              "name": "punctuation.section.block.begin.mar"
            }
          }
        },
        {
          "name": "meta.action.input.mar",
          "match": "\\b(input)\\s*(:)\\s*([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.language.mar"
            },
            "2": {
              "name": "punctuation.separator.key-value.mar"
            },
            "3": {
              "name": "entity.name.type.mar"
            }
          }
        },
        {
          "name": "meta.action.create.mar",
          "match": "\\b(create)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.rule.mar"
            },
            "2": {
              "name": "entity.name.type.mar"
            }
          }
        },
        {
          "name": "meta.field.declaration.mar",
          "match": "\\b([a-z][A-Za-z0-9_]*)\\s*(:)\\s*(Int|String|Bool|Float|Posix)\\b",
          "captures": {
            "1": {
              "name": "variable.other.member.mar"
            },
            "2": {
              "name": "punctuation.separator.key-value.mar"
            },
            "3": {
              "name": "storage.type.mar"
            }
          }
        },
        {
          "name": "meta.authorize.action.mar",
          "match": "\\b(authorize)\\s+(all|list|get|create|update|delete)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.authorization.mar"
            },
            "2": {
              "name": "support.constant.action.mar"
            }
          }
        },
        {
          "name": "meta.rule.declaration.mar",
          "match": "\\b(rule)\\s+(\"[^\"]*\")\\s+(expect)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.rule.mar"
            },
            "2": {
              "name": "string.quoted.double.mar"
            },
            "3": {
              "name": "keyword.control.rule.mar"
            }
          }
        },
        {
          "name": "meta.action.field.assignment.mar",
          "match": "\\b([a-z][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.other.member.mar"
            },
            "2": {
              "name": "punctuation.separator.key-value.mar"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.declaration.mar",
          "match": "\\b(app|port|database|system|public|entity|auth|type|alias)\\b"
        },
        {
          "name": "keyword.control.rule.mar",
          "match": "\\b(rule|expect|when|authorize|action|create)\\b"
        },
        {
          "name": "keyword.other.auth.mar",
          "match": "\\b(code_ttl_minutes|session_ttl_hours|email_transport|email_from|email_subject|smtp_host|smtp_port|smtp_username|smtp_password_env|smtp_starttls)\\b"
        },
        {
          "name": "keyword.other.public.mar",
          "match": "\\b(dir|mount|spa_fallback)\\b"
        },
        {
          "name": "keyword.other.system.mar",
          "match": "\\b(request_logs_buffer|http_max_request_body_mb|auth_request_code_rate_limit_per_minute|auth_login_rate_limit_per_minute|security_frame_policy|security_referrer_policy|security_content_type_nosniff|sqlite_journal_mode|sqlite_synchronous|sqlite_foreign_keys|sqlite_busy_timeout_ms|sqlite_wal_autocheckpoint|sqlite_journal_size_limit_mb|sqlite_mmap_size_mb|sqlite_cache_size_kb)\\b"
        },
        {
          "name": "storage.modifier.mar",
          "match": "\\b(primary|auto|optional|default)\\b"
        },
        {
          "name": "keyword.operator.logical.mar",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "support.function.mar",
          "match": "\\b(contains|startsWith|endsWith|len|matches|isRole)\\b(?=\\s*\\()"
        },
        {
          "name": "variable.other.member.mar",
          "match": "\\binput\\.([a-z][A-Za-z0-9_]*)\\b"
        },
        {
          "name": "variable.language.mar",
          "match": "\\b(input|auth_authenticated|auth_email|auth_user_id|auth_role)\\b"
        },
        {
          "name": "support.constant.action.mar",
          "match": "\\b(list|get|create|update|delete)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mar",
          "match": "\\b(Int|String|Bool|Float|Posix)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.mar",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.mar",
          "match": "\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mar",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.mar",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.arithmetic.mar",
          "match": "\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.assignment.mar",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.mar",
          "match": "->"
        },
        {
          "name": "punctuation.section.block.begin.mar",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.mar",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.mar",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.mar",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.mar",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.mar",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.mar",
          "match": ","
        }
      ]
    }
  }
}
