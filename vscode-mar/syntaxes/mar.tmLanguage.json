{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Mar",
  "scopeName": "source.mar",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#definition-forms"
    },
    {
      "include": "#typed-field-heads"
    },
    {
      "include": "#forms"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#modifiers"
    },
    {
      "include": "#types"
    },
    {
      "include": "#symbols"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.mar",
          "match": ";.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mar",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mar",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "definition-forms": {
      "patterns": [
        {
          "name": "meta.definition.function.mar",
          "match": "(\\()\\s*(define)\\s+(\\()\\s*([a-z][a-z0-9-]*(?:-[a-z0-9]+)*)",
          "captures": {
            "1": {
              "name": "punctuation.section.parens.begin.mar"
            },
            "2": {
              "name": "keyword.control.definition.mar"
            },
            "3": {
              "name": "punctuation.section.parens.begin.mar"
            },
            "4": {
              "name": "entity.name.function.mar"
            }
          }
        },
        {
          "name": "meta.definition.mar",
          "match": "(\\()\\s*(define-app|define-screen|define-query|define-entity|define-action|define-record|define-type|define)\\s+([a-z][a-z0-9-]*(?:-[a-z0-9]+)*)",
          "captures": {
            "1": {
              "name": "punctuation.section.parens.begin.mar"
            },
            "2": {
              "name": "keyword.control.definition.mar"
            },
            "3": {
              "name": "entity.name.type.mar"
            }
          }
        }
      ]
    },
    "typed-field-heads": {
      "patterns": [
        {
          "name": "meta.field.typed-head.mar",
          "match": "(\\()\\s*((?!(?:maybe|list|result|unit)\\b)[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*)\\s+(?=(?:string|int|decimal|bool|date|datetime|cursor|\\((?:maybe|list|result|unit)\\b))",
          "captures": {
            "1": {
              "name": "punctuation.section.parens.begin.mar"
            },
            "2": {
              "name": "variable.other.member.mar"
            }
          }
        }
      ]
    },
    "forms": {
      "patterns": [
        {
          "name": "keyword.control.mar",
          "match": "(?<=\\()\\s*(backend|frontend|input|fields|belongs-to|unique|defaults|default|primary|auto|validate|authorize|where|order-by|limit|config|auth|entities|queries|actions|screens|public|system|database|server|port|ios|bundle-identifier|display-name|server-url|dir|mount|spa-fallback|request-logs-buffer|http-max-request-body-mb|sqlite-journal-mode|sqlite-synchronous|sqlite-foreign-keys|sqlite-busy-timeout-ms|sqlite-wal-autocheckpoint|sqlite-journal-size-limit-mb|sqlite-mmap-size-mb|sqlite-cache-size-kb|from|subject|smtp-host|smtp-port|smtp-username|smtp-password-env|smtp-starttls|code-ttl-minutes|session-ttl-hours|auth-request-code-rate-limit-per-minute|auth-login-rate-limit-per-minute|admin-ui-session-ttl-hours|security-frame-policy|security-referrer-policy|security-content-type-nosniff|msg|init|update|view|section|empty|button|link|list|create|edit|delete|load|read|go|back|command|row|title|subtitle|text|field|value|open|destination|disabled|text-input|textarea|toggle|select)(?![-_.a-z0-9])"
        },
        {
          "name": "support.function.mar",
          "match": "(?<=\\()\\s*(if|cond|match|let|let\\*|lambda|begin|error|and|or|not|get|assoc|authenticated\\?|anonymous\\?|same-user\\?|has-role\\?|just|nothing|ok|err|unit|cons|first|rest|empty\\?|map|filter|fold-left|fold-right|length|contains|starts-with|ends-with|matches|string-append|number->string|date->string|datetime->string)(?![-_.a-z0-9])"
        },
        {
          "name": "support.function.mar",
          "match": "(?<=\\()\\s*(=|!=|>|>=|<|<=|\\+|-|\\*|/)(?=\\s|\\))"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.mar",
          "match": "\\b(true|false|else|current-user|asc|desc)(?![-_.a-z0-9])"
        }
      ]
    },
    "modifiers": {
      "patterns": [
        {
          "name": "storage.modifier.mar",
          "match": "\\boptional\\b"
        }
      ]
    },
    "symbols": {
      "patterns": [
        {
          "name": "variable.other.mar",
          "match": "\\b[a-z][a-z0-9]*(?:[-_.][a-z0-9]+)*\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mar",
          "match": "\\b(string|int|decimal|bool|date|datetime|cursor|maybe|list|result|unit)(?![-_.a-z0-9])"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mar",
          "match": "\\b-?[0-9]+(?:\\.[0-9]+)?\\b"
        }
      ]
    }
  }
}
