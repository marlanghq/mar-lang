{
  "Mar App": {
    "prefix": "app",
    "description": "Create a full Mar app scaffold",
    "body": [
      "app ${1:MyApi}",
      "port ${2:4100}",
      "database \"${3:app.db}\"",
      "",
      "-- Extend the built-in User with extra profile fields if needed.",
      "entity User {",
      "  ${4:displayName}: String optional",
      "  ${5:rule \\\"Email must be valid\\\" expect matches \\\"^[^@\\\\s]+@[^@\\\\s]+\\\\.[^@\\\\s]+$\\\" email}",
      "  rule \"Role must be admin or user\" expect role == \"admin\" or role == \"user\"",
      "  authorize all when user_role == \"admin\"",
      "  authorize read when user_authenticated and (id == user_id or user_role == \"admin\")",
      "  authorize update when user_authenticated and (id == user_id or user_role == \"admin\")",
      "  authorize delete when user_role == \"admin\"",
      "}",
      "",
      "auth {",
      "  code_ttl_minutes 10",
      "  session_ttl_hours 24",
      "  email_transport console",
      "  email_from \"no-reply@example.local\"",
      "  email_subject \"Your ${1:MyApi} login code\"",
      "}",
      "",
      "entity ${6:Todo} {",
      "  id: Int primary auto",
      "  ${7:title}: String",
      "  authorize all when user_authenticated",
      "}",
      "",
      "type alias ${8:RegisterUserInput} =",
      "  { email : String",
      "  }",
      "",
      "action ${9:registerUser} {",
      "  input: ${8:RegisterUserInput}",
      "",
      "  create User {",
      "    email: input.email",
      "    role: \"user\"",
      "  }",
      "}"
    ]
  },
  "Mar Entity": {
    "prefix": "entity",
    "description": "Create an entity block",
    "body": [
      "entity ${1:EntityName} {",
      "  id: Int primary auto",
      "  ${2:name}: ${3:String}",
      "  ${4:rule \\\"Validation message\\\" expect true}",
      "  authorize all when ${5:user_authenticated}",
      "}"
    ]
  },
  "Mar Field": {
    "prefix": "field",
    "description": "Create a field declaration",
    "body": "${1:fieldName}: ${2|Int,String,Bool,Float,Posix|}${3|, optional, default, primary, auto, primary auto|}"
  },
  "Mar Field With Default": {
    "prefix": "fielddefault",
    "description": "Create a field declaration with a literal default",
    "body": "${1:fieldName}: ${2|Int,String,Bool,Float,Posix|} default ${3:value}"
  },
  "Mar Belongs To": {
    "prefix": "belongs_to",
    "description": "Create a belongs_to relationship inside an entity",
    "body": "belongs_to ${1:User}"
  },
  "Mar Belongs To Current User": {
    "prefix": "belongs_to_current_user",
    "description": "Create a belongs_to relationship managed by the authenticated user",
    "body": "belongs_to current_user"
  },
  "Mar Named Belongs To Current User": {
    "prefix": "belongs_to_named_current_user",
    "description": "Create a named belongs_to relationship managed by the authenticated user",
    "body": "belongs_to ${1:owner}: current_user"
  },
  "Mar Named Belongs To": {
    "prefix": "belongs_to_named",
    "description": "Create a named belongs_to relationship inside an entity",
    "body": "belongs_to ${1:owner}: ${2:User}${3: optional}"
  },
  "Mar Rule": {
    "prefix": "rule",
    "description": "Create a business rule inside an entity",
    "body": "rule \"${1:Validation message}\" expect ${2:expression}"
  },
  "Mar Authorize": {
    "prefix": "authorize",
    "description": "Create one authorize rule",
    "body": "authorize ${1|all,read,create,update,delete|} when ${2:user_authenticated}"
  },
  "Mar Auth Block": {
    "prefix": "auth",
    "description": "Create an auth configuration block",
    "body": [
      "auth {",
      "  code_ttl_minutes ${1:10}",
      "  session_ttl_hours ${2:24}",
      "  email_transport ${3|console,smtp|}",
      "  email_from \"${4:no-reply@example.local}\"",
      "  email_subject \"${5:Your login code}\"",
      "  smtp_host \"${6:smtp.example.com}\"",
      "  smtp_port ${7:587}",
      "  smtp_username \"${8:username}\"",
      "  smtp_password_env \"${9:SMTP_PASSWORD}\"",
      "  smtp_starttls ${10|true,false|}",
      "}"
    ]
  },
  "Mar Public Block": {
    "prefix": "public",
    "description": "Create a public static assets block (embedded in executable)",
    "body": [
      "public {",
      "  dir \"${1:./frontend/dist}\"",
      "  mount \"${2:/}\"",
      "  spa_fallback \"${3:index.html}\"",
      "}"
    ]
  },
  "Mar System Block": {
    "prefix": "system",
    "description": "Create a system runtime configuration block",
    "body": [
      "system {",
      "  request_logs_buffer ${1:200}",
      "  http_max_request_body_mb ${2:1}",
      "  auth_request_code_rate_limit_per_minute ${3:5}",
      "  auth_login_rate_limit_per_minute ${4:10}",
      "  security_frame_policy ${5|sameorigin,deny|}",
      "  security_referrer_policy ${6|strict-origin-when-cross-origin,no-referrer|}",
      "  security_content_type_nosniff ${7|true,false|}",
      "  sqlite_journal_mode ${8|wal,delete,truncate,persist,memory,off|}",
      "  sqlite_synchronous ${9|normal,full,extra,off|}",
      "  sqlite_foreign_keys ${10|true,false|}",
      "  sqlite_busy_timeout_ms ${11:5000}",
      "  sqlite_wal_autocheckpoint ${12:1000}",
      "  sqlite_journal_size_limit_mb ${13:64}",
      "  sqlite_mmap_size_mb ${14:128}",
      "  sqlite_cache_size_kb ${15:2000}",
      "}"
    ]
  },
  "Mar Authorize Pack": {
    "prefix": "authzcrud",
    "description": "Create full CRUD authorization rules",
    "body": [
      "authorize all when ${1:user_authenticated}",
      "authorize read when ${2:user_authenticated and (id == user_id or user_role == \"admin\")}",
      "authorize delete when ${5:user_role == \"admin\"}" 
    ]
  },
  "Mar Type Alias": {
    "prefix": "typealias",
    "description": "Create a type alias for action inputs",
    "body": [
      "type alias ${1:CreateOrderInput} =",
      "  { ${2:userId} : ${3:Int}",
      "  , ${4:total} : ${5:Float}",
      "  }"
    ]
  },
  "Mar Action Block": {
    "prefix": "action",
    "description": "Create an action block with typed input and write steps",
    "body": [
      "action ${1:placeOrder} {",
      "  input: ${2:PlaceOrderInput}",
      "",
      "  ${3:order} = create ${4:Order} {",
      "    ${5:userId}: input.${6:userId}",
      "  }",
      "}"
    ]
  },
  "Mar Load Step": {
    "prefix": "load",
    "description": "Load one row into an alias inside an action",
    "body": [
      "${1:todo} = load ${2:Todo} {",
      "  ${3:id}: input.${4:id}",
      "}"
    ]
  },
  "Mar Create Step": {
    "prefix": "create",
    "description": "Create one create step inside an action",
    "body": [
      "${1:order} = create ${2:Order} {",
      "  ${3:userId}: input.${4:userId}",
      "}"
    ]
  },
  "Mar Update Step": {
    "prefix": "update",
    "description": "Create one update step inside an action",
    "body": [
      "${1:updatedOrder} = update ${2:Order} {",
      "  ${3:id}: input.${4:id}",
      "  ${5:status}: ${6:\"confirmed\"}",
      "}"
    ]
  },
  "Mar Delete Step": {
    "prefix": "delete",
    "description": "Create one delete step inside an action",
    "body": [
      "${1:deletedOrder} = delete ${2:Order} {",
      "  ${3:id}: input.${4:id}",
      "}"
    ]
  },
  "Mar Multi-Create Action": {
    "prefix": "actioncreate",
    "description": "Create an action with multiple write steps",
    "body": [
      "action ${1:placeOrder} {",
      "  input: ${2:PlaceOrderInput}",
      "",
      "  ${3:order} = create ${4:Order} {",
      "    ${5:userId}: input.${6:userId}",
      "    ${7:total}: input.${8:total}",
      "  }",
      "",
      "  ${9:auditLog} = create ${10:AuditLog} {",
      "    ${11:userId}: input.${6:userId}",
      "    ${12:event}: \"order created\"",
      "  }",
      "",
      "  ${13:updatedInventory} = update ${14:Inventory} {",
      "    ${15:id}: input.${16:inventoryId}",
      "    ${17:stock}: input.${18:remainingStock}",
      "  }",
      "}"
    ]
  }
}
