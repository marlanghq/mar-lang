{
  "Mar App": {
    "prefix": "app",
    "description": "Create a full Mar app scaffold",
    "body": [
      "app ${1:MyApi}",
      "port ${2:4100}",
      "database \"${3:app.db}\"",
      "",
      "type ${4:UserRole} {",
      "  ${5:Admin}",
      "  ${6:Member}",
      "}",
      "",
      "-- Extend the built-in User with extra profile fields if needed.",
      "entity User {",
      "  displayName: String optional",
      "  role: ${4:UserRole}",
      "  ${7:rule \\\"Email must be valid\\\" expect matches \\\"^[^@\\\\s]+@[^@\\\\s]+\\\\.[^@\\\\s]+$\\\" email}",
      "  authorize create, update when user_role == ${5:Admin}",
      "  authorize read when user_authenticated and (id == user_id or user_role == ${5:Admin})",
      "  authorize update when user_authenticated and (id == user_id or user_role == ${5:Admin})",
      "  authorize delete when user_role == ${5:Admin}",
      "}",
      "",
      "auth {",
      "  code_ttl_minutes 10",
      "  session_ttl_hours 24",
      "  email_from \"no-reply@example.local\"",
      "  email_subject \"Your ${1:MyApi} login code\"",
      "}",
      "",
      "entity ${6:Todo} {",
      "  id: Int primary auto",
      "  ${8:title}: String",
      "  authorize read, create, update, delete when user_authenticated",
      "}",
      "",
      "type alias ${9:RegisterUserInput} =",
      "  { email : String",
      "  }",
      "",
      "action ${10:registerUser} {",
      "  input: ${9:RegisterUserInput}",
      "",
      "  create User {",
      "    email: input.email",
      "    role: ${6:Member}",
      "  }",
      "}"
    ]
  },
  "Mar Entity": {
    "prefix": "entity",
    "description": "Create an entity block",
    "body": [
      "entity ${1:EntityName} {",
      "  id: Int primary auto",
      "  ${2:name}: ${3:String}",
      "  ${4:rule \\\"Validation message\\\" expect true}",
      "  authorize read, create, update, delete when ${5:user_authenticated}",
      "}"
    ]
  },
  "Mar Field": {
    "prefix": "field",
    "description": "Create a field declaration",
    "body": "${1:fieldName}: ${2|Int,String,Bool,Float,Date,DateTime|}${3|, optional, default, primary, auto, primary auto|}"
  },
  "Mar Field With Default": {
    "prefix": "fielddefault",
    "description": "Create a field declaration with a literal default",
    "body": "${1:fieldName}: ${2|Int,String,Bool,Float,Date,DateTime|} default ${3:value}"
  },
  "Mar Belongs To": {
    "prefix": "belongs_to",
    "description": "Create a belongs_to relationship inside an entity",
    "body": "belongs_to ${1:User}"
  },
  "Mar Belongs To Current User": {
    "prefix": "belongs_to_current_user",
    "description": "Create a belongs_to relationship managed by the authenticated user",
    "body": "belongs_to current_user"
  },
  "Mar Named Belongs To Current User": {
    "prefix": "belongs_to_named_current_user",
    "description": "Create a named belongs_to relationship managed by the authenticated user",
    "body": "belongs_to ${1:owner}: current_user"
  },
  "Mar Named Belongs To": {
    "prefix": "belongs_to_named",
    "description": "Create a named belongs_to relationship inside an entity",
    "body": "belongs_to ${1:owner}: ${2:User}${3: optional}"
  },
  "Mar Rule": {
    "prefix": "rule",
    "description": "Create a business rule inside an entity",
    "body": "rule \"${1:Validation message}\" expect ${2:expression}"
  },
  "Mar Authorize": {
    "prefix": "authorize",
    "description": "Create one authorize rule",
    "body": "authorize ${1:read}, ${2:create}, ${3:update}, ${4:delete} when ${5:user_authenticated}"
  },
  "Mar Public Block": {
    "prefix": "public",
    "description": "Create a public static assets block (embedded in executable)",
    "body": [
      "public {",
      "  dir \"${1:./frontend/dist}\"",
      "  mount \"${2:/}\"",
      "  spa_fallback \"${3:index.html}\"",
      "}"
    ]
  },
  "Mar iOS Block": {
    "prefix": "ios",
    "description": "Create an iOS project generation block",
    "body": [
      "ios {",
      "  bundle_identifier \"${1:com.example.app}\"",
      "  display_name \"${2:My App}\"",
      "  server_url \"${3:https://example.com}\"",
      "}"
    ]
  },
  "Mar System Block": {
    "prefix": "system",
    "description": "Create a system runtime configuration block",
    "body": [
      "system {",
      "  request_logs_buffer ${1:200}",
      "  http_max_request_body_mb ${2:1}",
      "  sqlite_journal_mode ${3|wal,delete,truncate,persist,memory,off|}",
      "  sqlite_synchronous ${4|normal,full,extra,off|}",
      "  sqlite_foreign_keys ${5|true,false|}",
      "  sqlite_busy_timeout_ms ${6:5000}",
      "  sqlite_wal_autocheckpoint ${7:1000}",
      "  sqlite_journal_size_limit_mb ${8:64}",
      "  sqlite_mmap_size_mb ${9:128}",
      "  sqlite_cache_size_kb ${10:2000}",
      "}"
    ]
  },
  "Mar Auth Block": {
    "prefix": "auth",
    "description": "Create an auth configuration block",
    "body": [
      "auth {",
      "  code_ttl_minutes ${1:10}",
      "  session_ttl_hours ${2:24}",
      "  auth_request_code_rate_limit_per_minute ${3:5}",
      "  auth_login_rate_limit_per_minute ${4:10}",
      "  admin_ui_session_ttl_hours ${5:2}",
      "  security_frame_policy ${6|sameorigin,deny|}",
      "  security_referrer_policy ${7|strict-origin-when-cross-origin,no-referrer|}",
      "  security_content_type_nosniff ${8|true,false|}",
      "  email_from \"${9:no-reply@mar.local}\"",
      "  email_subject \"${10:Your Mar login code}\"",
      "  smtp_host \"${11:smtp.example.com}\"",
      "  smtp_port ${12:587}",
      "  smtp_username \"${13:apikey}\"",
      "  smtp_password_env \"${14:SMTP_PASSWORD}\"",
      "  smtp_starttls ${15:true}",
      "}"
    ]
  },
  "Mar Authorize Pack": {
    "prefix": "authzcrud",
    "description": "Create full CRUD authorization rules",
    "body": [
      "authorize read, create, update, delete when ${1:user_authenticated}",
      "authorize read when ${2:user_authenticated and (id == user_id or user_role == \"admin\")}",
      "authorize delete when ${5:user_role == \"admin\"}" 
    ]
  },
  "Mar Type Alias": {
    "prefix": "typealias",
    "description": "Create a type alias for action inputs",
    "body": [
      "type alias ${1:CreateOrderInput} =",
      "  { ${2:user} : ref ${3:User}",
      "  , ${4:total} : ${5:Float}",
      "  }"
    ]
  },
  "Mar Type": {
    "prefix": "type",
    "description": "Create a closed type with named values",
    "body": [
      "type ${1:UserRole} {",
      "  ${2:Admin}",
      "  ${3:Member}",
      "}"
    ]
  },
  "Mar Screens Block": {
    "prefix": "screens",
    "description": "Create a screens navigation block",
    "body": [
      "screens {",
      "  screen ${1:Home} {",
      "    title \"${2:Home}\"",
      "",
      "    section \"${3:Browse}\" {",
      "      link \"${4:Items}\" to ${5:Items}",
      "    }",
      "  }",
      "",
      "  screen ${5:Items} {",
      "    title \"${4:Items}\"",
      "",
      "    section {",
      "      list ${6:Item} {",
      "        title ${7:name}",
      "        destination ${8:ItemDetail}",
      "      }",
      "    }",
      "  }",
      "",
      "  screen ${8:ItemDetail} for ${6:Item} {",
      "    title \"${9:Item}\"",
      "",
      "    section {",
      "      field ${7:name}",
      "    }",
      "  }",
      "}"
    ]
  },
  "Mar Frontend Screen": {
    "prefix": "screen",
    "description": "Create a screens screen",
    "body": [
      "screen ${1:ScreenName}${2: for EntityName} {",
      "  title \"${3:Screen title}\"",
      "",
      "  section {",
      "    ${4:field name}",
      "  }",
      "}"
    ]
  },
  "Mar Frontend Section": {
    "prefix": "section",
    "description": "Create a screens section",
    "body": [
      "section \"${1:Section}\" {",
      "  ${2:field name}",
      "}"
    ]
  },
  "Mar Frontend List": {
    "prefix": "frontlist",
    "description": "Create a screens entity list",
    "body": [
      "list ${1:Entity} {",
      "  title ${2:name}",
      "  ${3:subtitle description}",
      "  destination ${4:EntityDetail}",
      "}"
    ]
  },
  "Mar Frontend Children": {
    "prefix": "children",
    "description": "Create a screens child list from belongs_to",
    "body": [
      "children ${1:Comment} by ${2:post} {",
      "  title ${3:body}",
      "  ${4:destination CommentDetail}",
      "}"
    ]
  },
  "Mar Action Block": {
    "prefix": "action",
    "description": "Create an action block with typed input and write steps",
    "body": [
      "action ${1:placeOrder} {",
      "  input: ${2:PlaceOrderInput}",
      "",
      "  ${3:item} = load ${4:Inventory} {",
      "    ${5:id}: input.${6:itemId}",
      "  }",
      "",
      "  rule \"${7:Item must be available}\" expect ${8:item.stock > 0}",
      "",
      "  ${9:order} = create ${10:Order} {",
      "    ${11:userId}: input.${12:userId}",
      "  }",
      "}"
    ]
  },
  "Mar Action Rule": {
    "prefix": "actionrule",
    "description": "Create a validation rule inside an action",
    "body": [
      "rule \"${1:Business rule failed}\" expect ${2:condition}"
    ]
  },
  "Mar Load Step": {
    "prefix": "load",
    "description": "Load one row into an alias inside an action",
    "body": [
      "${1:todo} = load ${2:Todo} {",
      "  ${3:id}: input.${4:id}",
      "}"
    ]
  },
  "Mar Create Step": {
    "prefix": "create",
    "description": "Create one create step inside an action",
    "body": [
      "${1:order} = create ${2:Order} {",
      "  ${3:userId}: input.${4:userId}",
      "}"
    ]
  },
  "Mar Update Step": {
    "prefix": "update",
    "description": "Create one update step inside an action",
    "body": [
      "${1:updatedOrder} = update ${2:Order} {",
      "  ${3:id}: input.${4:id}",
      "  ${5:status}: ${6:\"confirmed\"}",
      "}"
    ]
  },
  "Mar Delete Step": {
    "prefix": "delete",
    "description": "Create one delete step inside an action",
    "body": [
      "${1:deletedOrder} = delete ${2:Order} {",
      "  ${3:id}: input.${4:id}",
      "}"
    ]
  },
  "Mar Multi-Create Action": {
    "prefix": "actioncreate",
    "description": "Create an action with multiple write steps",
    "body": [
      "action ${1:placeOrder} {",
      "  input: ${2:PlaceOrderInput}",
      "",
      "  ${3:order} = create ${4:Order} {",
      "    ${5:userId}: input.${6:userId}",
      "    ${7:total}: input.${8:total}",
      "  }",
      "",
      "  ${9:auditLog} = create ${10:AuditLog} {",
      "    ${11:userId}: input.${6:userId}",
      "    ${12:event}: \"order created\"",
      "  }",
      "",
      "  ${13:updatedInventory} = update ${14:Inventory} {",
      "    ${15:id}: input.${16:inventoryId}",
      "    ${17:stock}: input.${18:remainingStock}",
      "  }",
      "}"
    ]
  }
}
