{
  "Mar App": {
    "prefix": "define-app",
    "description": "Create a Mar app scaffold",
    "body": [
      "(define ${1:todo}",
      "  (entity",
      "    (fields",
      "      ((title string)",
      "       (done bool)))",
      "    (validate",
      "      (if (>= (length title) 3)",
      "          true",
      "          (error \"title must have at least 3 chars\")))",
      "    (authorize",
      "      (((read create update delete)",
      "         (authenticated? current-user))))))",
      "",
      "(define-record ${2:home-model}",
      "  (error (maybe string)))",
      "",
      "(define-screen ${3:home}",
      "  (view",
      "    (section",
      "      (title \"${4:Home}\")",
      "      (text \"${5:Hello from Mar}\"))))",
      "",
      "(define-app ${6:my-app}",
      "  (backend",
      "    (entities ${1:todo}))",
      "  (frontend",
      "    (screens ${3:home})))"
    ]
  },
  "Mar Record": {
    "prefix": "define-record",
    "description": "Create a record definition",
    "body": [
      "(define-record ${1:todo-model}",
      "  (${2:count} int)",
      "  (${3:error} (maybe string)))"
    ]
  },
  "Mar Type": {
    "prefix": "define-type",
    "description": "Create a tagged union type",
    "body": [
      "(define-type ${1:screen-state}",
      "  (${2:loading})",
      "  (${3:loaded} (${4:items} (list ${5:item})))",
      "  (${6:failed} (${7:message} string)))"
    ]
  },
  "Mar Entity": {
    "prefix": "entity",
    "description": "Create a named entity value",
    "body": [
      "(define ${1:entity-name}",
      "  (entity",
      "    (fields",
      "      ((${2:field-name} ${3|string,int,decimal,bool,date,datetime,cursor|})))",
      "    (unique",
      "      ((${2:field-name}))))"
    ]
  },
  "Mar Action": {
    "prefix": "action",
    "description": "Create a backend action definition",
    "body": [
      "(define ${1:create-item}",
      "  (action",
      "    (input",
      "      ((${2:title} ${3|string,int,decimal,bool,date,datetime,cursor|})))",
      "    (create ${4:todo}",
      "      ((${2:title} ${2:title})))))"
    ]
  },
  "Mar Screen": {
    "prefix": "screen",
    "description": "Create a dynamic MVU screen",
    "body": [
      "(define-screen (${1:orders-by-status} ${2:wanted-status})",
      "  (msg",
      "    (${3:loaded} items)",
      "    (${4:failed} message))",
      "  (init",
      "    ((${5:screen-model}",
      "       (${6:items} ())",
      "       (${7:loading} true))",
      "     ((command (${8:load-items} ${2:wanted-status}) ${3:loaded} ${4:failed}))))",
      "  (update msg model",
      "    (match msg",
      "      ((${3:loaded} items)",
      "       ((assoc model",
      "          (${6:items} items)",
      "          (${7:loading} false))",
      "        ()))",
      "      ((${4:failed} message)",
      "       ((assoc model",
      "          (${7:loading} false))",
      "        ()))))",
      "  (view model",
        "    (section",
        "      (title \"${9:Items}\")",
        "      (text \"${10:Loading...}\"))))"
    ]
  },
  "Mar Static Screen": {
    "prefix": "static-screen",
    "description": "Create a static screen with a view",
    "body": [
      "(define-screen ${1:home}",
      "  (view",
      "    (section",
      "      (title \"${2:Home}\")",
      "      (text \"${3:Hello from Mar}\"))))"
    ]
  },
  "Mar Query": {
    "prefix": "query",
    "description": "Create a zero-arg query definition",
    "body": [
      "(define (${1:my-items})",
      "  (query ${2:entity}",
      "    (where ${3:(authenticated? current-user)})",
      "    (order-by ${4:title} desc)",
      "    (limit ${5:20})))"
    ]
  },
  "Mar Button": {
    "prefix": "button",
    "description": "Create a button that emits a screen message",
    "body": ["(button \"${1:Save}\" ${2:save-clicked} (disabled ${3:saving}))"]
  },
  "Mar List": {
    "prefix": "list",
    "description": "Create a list section item",
    "body": [
      "(list ${1:todo}",
      "  ((title ${2:title})",
      "   (subtitle ${3:created-at})",
      "   (open ${4:todo-detail})))"
    ]
  },
  "Mar Result": {
    "prefix": "result",
    "description": "Create a result type or value pattern",
    "body": [
      "(result ${1:string} ${2:(list item)})"
    ]
  },
  "Mar Maybe": {
    "prefix": "maybe",
    "description": "Create a maybe type",
    "body": [
      "(maybe ${1:string})"
    ]
  },
  "Mar Cursor": {
    "prefix": "cursor",
    "description": "Insert the cursor type",
    "body": [
      "cursor"
    ]
  }
}
