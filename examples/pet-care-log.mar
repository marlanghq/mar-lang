(define-entity pet
    (fields ((name string) (species string)))
    (belongs-to ((owner user)))
    (defaults ((owner current-user))))

(define-entity vet-visit
    (fields ((visit-date date) (reason string)))
    (belongs-to ((pet) (user)))
    (defaults ((user current-user))))

(define-screen pets
  (view
    (section
      (title "Pets")
      (text
        "Pet Care Log tracks pets and vet visits tied back to each owner."))))

(define-app pet-care-log
  (backend (entities pet vet-visit))
  (frontend (screens pets)))
