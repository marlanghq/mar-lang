(define ticket
  (entity
    (fields ((subject string) (status string)))
    (belongs-to ((requester user)))
    (defaults ((requester current-user)))))

(define-screen tickets
  (view
    (section
      (title "Tickets")
      (text "Support desk keeps tickets tied to the authenticated requester."))))

(define-app support-desk
  (backend (entities ticket))
  (frontend (screens tickets)))
