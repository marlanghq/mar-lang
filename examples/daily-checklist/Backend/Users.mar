module Backend.Users exposing (users)


import Shared


-- The users table backs Auth.config. Auth.* operations (signup,
-- requestCode, verifyCode, me) read and write rows here via the
-- Entity handle below. No business logic of our own — the framework
-- owns it.
users : Entity Shared.User
users =
    Entity.define
        { name = "users"
        , columns =
            { id    = Entity.serial
            , email = Entity.text Entity.notNull
            }
        , uniques = []
        }
