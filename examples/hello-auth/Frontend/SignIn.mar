module Frontend.SignIn exposing (page)


import Frontend.Routes
import UI exposing
    ( navigationStack, navigationTitle
    , form, section, text, textField, button, errorText
    , email, submit, empty, disabled
    , width, chars
    )


-- Email-entry half of the sign-in flow.
--
-- On successful Auth.requestCode, navigate to /sign-in/verify/<email>.
-- Splitting the flow across two pages gives us the back button for
-- free: a user who mistyped their email taps Back on the verify page
-- and lands here with the email field blank, ready to try again.


type alias Model =
    { draft : String
    , error : Maybe String
    , busy  : Bool
    }


type Msg
    = DraftChanged String
    | Submitted
    | CodeRequested (Result String ())


init : (Model, Effect String Msg)
init =
    ( { draft = "", error = Nothing, busy = False }, Effect.none )


update : Msg -> Model -> (Model, Effect String Msg)
update msg model =
    case msg of
        DraftChanged value ->
            -- Typing clears the previous error so a stale failure
            -- doesn't sit on top of a fresh attempt.
            ( { model | draft = value, error = Nothing }, Effect.none )

        Submitted ->
            -- Guard against re-entry: a stray Enter while busy or a
            -- racing tap could fire Submitted twice. Drop duplicates
            -- so we don't issue two requestCode calls.
            if model.busy then
                ( model, Effect.none )
            else
                ( { model | busy = True, error = Nothing }
                , Auth.requestCode { email = model.draft } CodeRequested
                )

        CodeRequested (Ok ()) ->
            ( { model | busy = False }
            , Nav.pushTo Frontend.Routes.verifyCode { email = model.draft }
            )

        CodeRequested (Err why) ->
            ( { model | busy = False, error = Just (explainError why) }
            , Effect.none
            )


explainError : String -> String
explainError code =
    case code of
        "invalid_email" ->
            "That doesn't look like a valid email address."

        "missing_email" ->
            "Email is required."

        "rate_limited" ->
            "Too many attempts. Wait a moment before trying again."

        _ ->
            code


view : Model -> View Msg
view model =
    navigationStack [ navigationTitle "Sign in" ]
        [ form
            [ section []
                [ text [] "Enter your email and we'll send you a one-time code."
                , textField
                    [ email, submit Submitted, width (chars 30) ]
                    "Email" model.draft DraftChanged
                , errorView model.error
                ]
            , section []
                [ button [ disabled model.busy ] Submitted "Send me a code" ]
            ]
        ]


errorView : Maybe String -> View Msg
errorView maybeErr =
    case maybeErr of
        Nothing ->
            empty

        Just msg ->
            errorText msg


page : Page
page =
    Page.create
        { path   = "/sign-in"
        , title  = "Sign in"
        , init   = init
        , update = update
        , view   = view
        }
