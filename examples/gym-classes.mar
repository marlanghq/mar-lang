(define gym
  (entity
    (fields ((name string)))))

(define workout-class
  (entity
    (fields ((title string) (starts-at datetime)))
    (belongs-to ((gym)))))

(define-screen classes
  (view
    (section
      (title "Classes")
      (text "Gym classes connect each workout class to a gym and start time."))))

(define-app gym-classes
  (backend (entities gym workout-class))
  (frontend (screens classes)))
