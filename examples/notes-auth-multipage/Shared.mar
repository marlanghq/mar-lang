module Shared exposing (..)


-- Types and Service contracts shared between frontend and backend.


type alias User =
    { id    : Int
    , email : String
    }


type alias Note =
    { id       : Int
    , body     : String
    , authorId : Int
    }


type alias NewNote =
    { body : String
    }


listMine : Service () (List Note)
listMine =
    Service.declare


createMine : Service NewNote Note
createMine =
    Service.declare
