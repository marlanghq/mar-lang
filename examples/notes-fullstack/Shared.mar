module Shared exposing (..)


-- Shared between Backend.mar and Frontend.mar.
--
-- backendBase is a relative URL because in `mar app` mode the backend is
-- served at /api on the same origin as the frontend.


backendBase : String
backendBase =
    "/api"


listEp : Endpoint
listEp =
    Endpoint.get "/notes"


createEp : Endpoint
createEp =
    Endpoint.post "/notes"
