(define-entity todo-list
    (fields ((name string))))

(define-entity todo
    (fields ((title string) (done bool)))
    (belongs-to ((todo-list) (owner user)))
    (defaults ((owner current-user))))

(define-screen home
  (view
    (section
      (title "Shared todo")
      (text
        "Shared todo models lists plus items that belong to a current-user owner."))))

(define-app shared-todo
  (backend (entities todo-list todo))
  (frontend (screens home)))
