(define product
  (entity
    (fields ((name string) (price decimal)))))

(define order
  (entity
    (fields ((status string)))
    (belongs-to ((customer user)))
    (defaults ((customer current-user)))))

(define-screen products
  (view
    (section
      (title "Store")
      (text
        "Store models products with decimal prices and user-owned orders."))))

(define-app store
  (backend (entities product order))
  (frontend (screens products)))
