    }


-- ====================================================================
-- MILESTONES
-- ====================================================================

type MilestoneStatus
    = MilestoneOpen
    | MilestoneClosed


type alias Milestone =
    { id          : Int
    , projectId   : Int
    , name        : String
    , description : String
    , status      : MilestoneStatus
    , createdAt   : Time
    }


type alias NewMilestone =
    { projectId   : Int
    , name        : String
    , description : String
    }


type alias CloseMilestone =
    { id : Int
    }


type alias ReopenMilestone =
    { id : Int
    }


type alias ListProjectMilestones =
    { projectId : Int
    }


-- ====================================================================
-- TEAM MEMBERSHIP
-- ====================================================================

type alias TeamMemberView =
    { id          : Int
    , email       : String
    , name        : String
    , role        : Role
    , createdAt   : Time
    , openIssues  : Int
    }


type alias UpdateMemberRole =
    { userId : Int
    , role   : Role
    }


-- ====================================================================
-- DASHBOARD
-- ====================================================================

-- Single round-trip payload for the Dashboard page. Bundling four
-- related lists into one Service call keeps the initial render
-- waterfall-free: the page mounts with everything it needs from a
-- single fetch instead of fanning out to four endpoints.
type alias DashboardData =
    { projects        : List Project
    , myOpenIssues    : List IssueView
    , recentlyUpdated : List IssueView
    , teamMembers     : List TeamMemberView
    }


-- ====================================================================
-- SERVICE CONTRACTS
-- ====================================================================
--
-- Each Service.declare is a typed RPC between frontend and backend.
-- The backend implements it in Backend/*; the frontend calls it via
-- Service.call. The compiler enforces that argument and return
-- shapes line up — adding a field here ripples into every consumer.


-- Projects
listProjects : Service () (List Project)
listProjects = Service.declare

getProject : Service GetProject (Maybe Project)
getProject = Service.declare

createProject : Service NewProject Project
createProject = Service.declare

editProject : Service EditProject (Maybe Project)
editProject = Service.declare

deleteProject : Service DeleteProject ()
deleteProject = Service.declare


-- Issues
listProjectIssues : Service ListProjectIssues (List IssueView)
listProjectIssues = Service.declare

getIssue : Service GetIssue (Maybe IssueView)
getIssue = Service.declare

createIssue : Service NewIssue Issue
createIssue = Service.declare

editIssue : Service EditIssue (Maybe Issue)
editIssue = Service.declare

changeIssueStatus : Service ChangeStatus (Maybe Issue)
changeIssueStatus = Service.declare

deleteIssue : Service DeleteIssue ()
deleteIssue = Service.declare

myOpenIssues : Service () (List IssueView)
myOpenIssues = Service.declare

searchIssues : Service SearchIssues (List IssueView)
searchIssues = Service.declare


-- Comments
listComments : Service ListComments (List CommentView)
listComments = Service.declare

createComment : Service NewComment Comment
createComment = Service.declare

deleteComment : Service DeleteComment ()
deleteComment = Service.declare

-- Toggle a reaction: insert when absent, remove when present.
-- Idempotent UX-wise; backend enforces uniqueness via
-- Entity.unique [["commentId","userId","emoji"]].
toggleReaction : Service ToggleReaction ()
toggleReaction = Service.declare


-- Labels
listProjectLabels : Service ListProjectLabels (List Label)
listProjectLabels = Service.declare

createLabel : Service NewLabel Label
createLabel = Service.declare

deleteLabel : Service DeleteLabel ()
deleteLabel = Service.declare

attachLabel : Service AttachLabel IssueLabel
attachLabel = Service.declare

detachLabel : Service DetachLabel ()
detachLabel = Service.declare

listIssueLabels : Service ListIssueLabels (List Label)
listIssueLabels = Service.declare


-- Milestones
listProjectMilestones : Service ListProjectMilestones (List Milestone)
listProjectMilestones = Service.declare

createMilestone : Service NewMilestone Milestone
createMilestone = Service.declare

closeMilestone : Service CloseMilestone (Maybe Milestone)
closeMilestone = Service.declare

reopenMilestone : Service ReopenMilestone (Maybe Milestone)
reopenMilestone = Service.declare


-- Team
listTeamMembers : Service () (List TeamMemberView)
listTeamMembers = Service.declare

updateMemberRole : Service UpdateMemberRole (Maybe User)
updateMemberRole = Service.declare


-- Dashboard
loadDashboard : Service () DashboardData
loadDashboard = Service.declare


-- Activity feed
listRecentActivity : Service ListRecentActivity (List ActivityView)
listRecentActivity = Service.declare


-- Mentions / Inbox
listMyMentions : Service ListMyMentions (List MentionView)
listMyMentions = Service.declare

markMentionSeen : Service MarkMentionSeen ()
markMentionSeen = Service.declare


-- ====================================================================
-- DISPLAY HELPERS
-- ====================================================================

-- Plain-text label for each status. Used in dropdowns, badges, and
-- the section headers on filtered lists. Kept here so frontend AND
-- backend agree on the user-facing string.
statusLabel : IssueStatus -> String
statusLabel s =
    case s of
        Open        -> "Open"
        InProgress  -> "In progress"
        Done        -> "Done"
        WontFix     -> "Won't fix"


priorityLabel : IssuePriority -> String
priorityLabel p =
    case p of
        NoPriority -> "No priority"
        Low        -> "Low"
        Medium     -> "Medium"
        High       -> "High"
        Urgent     -> "Urgent"


roleLabel : Role -> String
roleLabel r =
    case r of
        Admin  -> "Admin"
        Member -> "Member"


milestoneStatusLabel : MilestoneStatus -> String
milestoneStatusLabel s =
    case s of
        MilestoneOpen   -> "Open"
        MilestoneClosed -> "Closed"


-- Pretty-printed issue handle: "ProjectName · #42 — Title"
issueHandle : IssueView -> String
issueHandle i =
    i.projectName ++ " · #" ++ String.fromInt i.number ++ " — " ++ i.title
