module Shared exposing (..)


-- BigApp domain — a project-management / issue tracker built to
-- stress-test the mar compiler over a realistic multi-module
-- codebase. Models the kind of system a small team would build to
-- manage their own work: teams own projects, projects contain
-- issues, issues collect comments, get labeled, grouped into
-- milestones, and assigned to teammates.
--
-- This module is the contract layer. Both Backend (which implements
-- services) and Frontend (which calls them) import from here. Every
-- entity record, every Service.declare, every enum lives in one
-- place so renaming a field shows up as compile errors everywhere
-- it's consumed.


-- ====================================================================
-- ACTIVITY
-- ====================================================================
--
-- Activities are append-only audit log entries: one row per
-- significant action (issue created, status changed, commented,
-- reaction added, …). They're a derived denormalization of what
-- happens across the system — handlers in the writeful services
-- emit an activity row as a side effect of the primary write.
--
-- Verb is a closed enum so the frontend can render verb-specific
-- copy ("Marcio opened issue #42" vs "Marcio commented on #42")
-- without a fragile string match.
--
-- Subject is the resource the action targets. Three flavors
-- (Project / Issue / Comment) cover the surface today; adding a
-- fourth means one new ctor + one new render branch.

type ActivityVerb
    = CreatedIssue
    | ChangedIssueStatus
    | DeletedIssue
    | CommentedOnIssue
    | DeletedComment
    | ReactedToComment
    | CreatedProject
    | DeletedProject


type ActivitySubject
    = OnProject
    | OnIssue
    | OnComment


-- The stored row. `subjectId` carries the id of the target resource;
-- `extra` carries verb-specific context (status name, emoji, etc.)
-- as a free-form string so a single shape works for every verb. The
-- view layer parses extra according to the verb.
type alias Activity =
    { id        : Int
    , teamId    : Int
    , actorId   : Int
    , verb      : ActivityVerb
    , subject   : ActivitySubject
    , subjectId : Int
    , extra     : String
    , createdAt : Time
    }


-- ActivityView: what the frontend renders. We denormalize actor
-- name and (where applicable) the issue's project + number so the
-- timeline doesn't need per-row lookups in the browser.
type alias ActivityView =
    { id          : Int
    , actorId     : Int
    , actorName   : String
    , verb        : ActivityVerb
    , subject     : ActivitySubject
    , subjectId   : Int
    , extra       : String
    , -- When subject == OnIssue or OnComment, these point at the
      -- parent issue's metadata so the timeline can deep-link.
      -- Empty (0 / "") when not applicable.
      issueNumber : Int
    , issueTitle  : String
    , projectSlug : String
    , createdAt   : Time
    }


type alias ListRecentActivity =
    { limit : Int    -- 0 = use default
    }


-- ====================================================================
-- IDENTITY + AUTHORIZATION
-- ====================================================================

-- Two roles. Admin can manage team membership + delete other people's
-- content; Member can do everything else. Stored as `Entity.enum`
-- in the users table → TEXT with a CHECK constraint, so a typo in
-- `Auth.requireRole Adimn` is a compile error not a never-allowed
-- runtime path.
type Role
    = Admin
    | Member


type alias User =
    { id        : Int
    , email     : String
    , name      : String
    , teamId    : Int
    , role      : Role
    , createdAt : Time
    }


type alias Team =
    { id        : Int
    , name      : String
    , slug      : String
    , createdAt : Time
    }


-- ====================================================================
-- PROJECTS
-- ====================================================================

type alias Project =
    { id          : Int
    , teamId      : Int
    , name        : String
    , slug        : String
    , description : String
    , createdAt   : Time
    }


-- Service input types — small records so callers (frontend, iOS) can
-- build them without referring to the full entity. Keeps the public
-- API of each Service.* small and explicit.
type alias NewProject =
    { name        : String
    , slug        : String
    , description : String
    }


type alias GetProject =
    { id : Int
    }


type alias EditProject =
    { id          : Int
    , name        : String
    , description : String
    }


type alias DeleteProject =
    { id : Int
    }


-- ====================================================================
-- ISSUES
-- ====================================================================

-- Lifecycle of an issue:
--
--   Open ──→ InProgress ──→ Done
--     ↑                       │
--     └────── reopen ─────────┘
--
-- Closed-as-WontFix is a separate terminal state from Done — Done
-- means "the work is finished and shipped", WontFix means "we
-- decided not to do it". UI surfaces them differently (Done = green
-- check, WontFix = gray) so the team can reason about trade-offs at
-- review time.
type IssueStatus
    = Open
    | InProgress
    | Done
    | WontFix


-- Priority — four levels mapping to the standard "urgency × impact"
-- grid. Stored as enum, so adding a new priority is a one-line
-- change here + the migration that follows.
type IssuePriority
    = NoPriority
    | Low
    | Medium
    | High
    | Urgent


type alias Issue =
    { id          : Int
    , projectId   : Int
    , number      : Int          -- per-project counter, surfaced to humans as "PROJ-42"
    , title       : String
    , description : String
    , status      : IssueStatus
    , priority    : IssuePriority
    , assigneeId  : Int          -- 0 = unassigned (no nullable column needed)
    , reporterId  : Int
    , milestoneId : Int          -- 0 = no milestone
    , createdAt   : Time
    , updatedAt   : Time
    }


-- IssueView denormalizes the issue with author + assignee info so
-- the frontend doesn't have to fan out N+1 lookups. The backend
-- builds this server-side; the wire format trades a slightly bigger
-- payload for an instant render.
type alias IssueView =
    { id              : Int
    , projectId       : Int
    , projectSlug     : String
    , projectName     : String
    , number          : Int
    , title           : String
    , description     : String
    , status          : IssueStatus
    , priority        : IssuePriority
    , assigneeId      : Int
    , assigneeName    : String
    , assigneeEmail   : String
    , reporterId      : Int
    , reporterName    : String
    , reporterEmail   : String
    , milestoneId     : Int
    , milestoneName   : String
    , commentCount    : Int
    , createdAt       : Time
    , updatedAt       : Time
    }


type alias NewIssue =
    { projectId   : Int
    , title       : String
    , description : String
    , priority    : IssuePriority
    , assigneeId  : Int
    , milestoneId : Int
    }


type alias GetIssue =
    { id : Int
    }


type alias EditIssue =
    { id          : Int
    , title       : String
    , description : String
    , priority    : IssuePriority
    , assigneeId  : Int
    , milestoneId : Int
    }


type alias ChangeStatus =
    { id     : Int
    , status : IssueStatus
    }


type alias DeleteIssue =
    { id : Int
    }


type alias ListProjectIssues =
    { projectId : Int
    , status    : IssueStatus  -- pass Open as the "show me everything" sentinel; filter helpers expand on this server-side
    , showAll   : Bool          -- when true, ignore status and return every issue
    }


type alias SearchIssues =
    { query : String
    }


-- ====================================================================
-- COMMENTS
-- ====================================================================

type alias Comment =
    { id        : Int
    , issueId   : Int
    , authorId  : Int
    , body      : String
    , createdAt : Time
    }


-- ====================================================================
-- REACTIONS
-- ====================================================================
--
-- Declared BEFORE CommentView because CommentView's `reactions`
-- field references ReactionSummary. (Mar's type-alias resolution
-- expects forward declarations to be in source order.)
--
-- One row per (comment, user, emoji) triple. Composite UNIQUE on
-- that triple keeps "Marcio added 👍" idempotent — clicking the
-- same emoji twice toggles instead of stacking. The toggle service
-- inserts when absent, deletes when present.

type alias Reaction =
    { id        : Int
    , commentId : Int
    , userId    : Int
    , emoji     : String
    , createdAt : Time
    }


type alias ReactionSummary =
    { emoji   : String
    , count   : Int
    , mineToo : Bool
    }


type alias ToggleReaction =
    { commentId : Int
    , emoji     : String
    }


-- ====================================================================
-- MENTIONS
-- ====================================================================
--
-- A mention is "I (commenter) called you out by @handle". One row
-- per (comment, mentioned-user) pair — the UNIQUE on those two
-- columns means a comment can mention the same person five times in
-- its body and still produce a single inbox entry. Mentions are
-- never edited; if a comment is deleted, its mentions cascade away
-- via the delete handler.
--
-- The `seen` field lets the Inbox page mark items as read without
-- deleting the row, so "how many unread mentions" stays answerable.

type alias Mention =
    { id              : Int
    , commentId       : Int
    , mentionedUserId : Int
    , authorId        : Int
    , createdAt       : Time
    , seen            : Bool
    }


-- View shape served to the Inbox page: denormalizes everything the
-- UI needs (author name, issue context, comment snippet) so the
-- frontend doesn't fan out per-row lookups.
type alias MentionView =
    { id              : Int
    , commentId       : Int
    , mentionedUserId : Int
    , authorId        : Int
    , authorName      : String
    , issueId         : Int
    , issueNumber     : Int
    , issueTitle      : String
    , projectSlug     : String
    , bodyPreview     : String
    , createdAt       : Time
    , seen            : Bool
    }


type alias ListMyMentions =
    { onlyUnseen : Bool
    }


type alias MarkMentionSeen =
    { id : Int
    }


type alias CommentView =
    { id          : Int
    , issueId     : Int
    , authorId    : Int
    , authorName  : String
    , authorEmail : String
    , body        : String
    , createdAt   : Time
    , reactions   : List ReactionSummary
    }


type alias NewComment =
    { issueId : Int
    , body    : String
    }


type alias DeleteComment =
    { id : Int
    }


type alias ListComments =
    { issueId : Int
    }


