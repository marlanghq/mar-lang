module Backend.Dashboard exposing (services)


import Backend.Projects
import Backend.Issues
import Backend.Teams
import Shared


-- Dashboard composes four related lists into a single round-trip
-- payload. Bundling them prevents the typical "fan out from /me to
-- /projects + /my-issues + /recent + /members" waterfall that makes
-- the first paint feel slow.


load : () -> Shared.User -> Task Shared.DashboardData
load _ user =
    Repo.findBy Backend.Projects.projects { teamId = user.teamId }
        |> Task.andThen
            (\projects ->
                Backend.Issues.listOpenForAssignee user
                    |> Task.andThen
                        (\myOpen ->
                            Backend.Issues.listRecent user
                                |> Task.andThen
                                    (\recent ->
                                        Backend.Teams.listMembers () user
                                            |> Task.map
                                                (\members ->
                                                    { projects        = projects
                                                    , myOpenIssues    = myOpen
                                                    , recentlyUpdated = recent
                                                    , teamMembers     = members
                                                    }
                                                )
                                    )
                        )
            )


services =
    [ Auth.protect Shared.loadDashboard load
    ]
