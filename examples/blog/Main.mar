module Main exposing (main)


import Post
import Format


posts : List Post.Post
posts =
    [ { id = Post.mkId 1
      , title = "Hello, mar"
      , body = "This is the first post."
      , published = True
      }
    , { id = Post.mkId 2
      , title = "Draft idea"
      , body = "Coming soon."
      , published = False
      }
    , Post.defaultPost |> Post.withTitle "Renamed"
    ]


main : List String
main =
    posts |> List.map Format.renderPost
