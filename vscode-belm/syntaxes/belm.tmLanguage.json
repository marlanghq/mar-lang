{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Belm",
  "scopeName": "source.belm",
  "patterns": [
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#literals"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-dash.belm",
          "match": "--.*$"
        },
        {
          "name": "comment.line.number-sign.belm",
          "match": "#.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.belm",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.belm"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.belm"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.belm",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.app.declaration.belm",
          "match": "\\b(app)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.belm"
            },
            "2": {
              "name": "entity.name.type.belm"
            }
          }
        },
        {
          "name": "meta.entity.declaration.belm",
          "match": "\\b(entity)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.belm"
            },
            "2": {
              "name": "entity.name.type.belm"
            }
          }
        },
        {
          "name": "meta.public.declaration.belm",
          "match": "\\b(public)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.belm"
            },
            "2": {
              "name": "punctuation.section.block.begin.belm"
            }
          }
        },
        {
          "name": "meta.system.declaration.belm",
          "match": "\\b(system)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.belm"
            },
            "2": {
              "name": "punctuation.section.block.begin.belm"
            }
          }
        },
        {
          "name": "meta.typealias.declaration.belm",
          "match": "\\b(type)\\s+(alias)\\s+([A-Z][A-Za-z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.belm"
            },
            "2": {
              "name": "keyword.control.declaration.belm"
            },
            "3": {
              "name": "entity.name.type.belm"
            },
            "4": {
              "name": "keyword.operator.assignment.belm"
            }
          }
        },
        {
          "name": "meta.auth.user-entity.belm",
          "match": "\\b(user_entity)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.auth.belm"
            },
            "2": {
              "name": "entity.name.type.belm"
            }
          }
        },
        {
          "name": "meta.action.declaration.belm",
          "match": "\\b(action)\\s+([a-z][A-Za-z0-9_]*)\\s*(\\{)",
          "captures": {
            "1": {
              "name": "keyword.control.declaration.belm"
            },
            "2": {
              "name": "entity.name.function.belm"
            },
            "3": {
              "name": "punctuation.section.block.begin.belm"
            }
          }
        },
        {
          "name": "meta.action.input.belm",
          "match": "\\b(input)\\s*(:)\\s*([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "variable.language.belm"
            },
            "2": {
              "name": "punctuation.separator.key-value.belm"
            },
            "3": {
              "name": "entity.name.type.belm"
            }
          }
        },
        {
          "name": "meta.action.create.belm",
          "match": "\\b(create)\\s+([A-Z][A-Za-z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.rule.belm"
            },
            "2": {
              "name": "entity.name.type.belm"
            }
          }
        },
        {
          "name": "meta.field.declaration.belm",
          "match": "\\b([a-z][A-Za-z0-9_]*)\\s*(:)\\s*(Int|String|Bool|Float)\\b",
          "captures": {
            "1": {
              "name": "variable.other.member.belm"
            },
            "2": {
              "name": "punctuation.separator.key-value.belm"
            },
            "3": {
              "name": "storage.type.belm"
            }
          }
        },
        {
          "name": "meta.authorize.action.belm",
          "match": "\\b(authorize)\\s+(list|get|create|update|delete)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.authorization.belm"
            },
            "2": {
              "name": "support.constant.action.belm"
            }
          }
        },
        {
          "name": "meta.rule.declaration.belm",
          "match": "\\b(rule)\\s+(\"[^\"]*\")\\s+(when)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.rule.belm"
            },
            "2": {
              "name": "string.quoted.double.belm"
            },
            "3": {
              "name": "keyword.control.rule.belm"
            }
          }
        },
        {
          "name": "meta.action.field.assignment.belm",
          "match": "\\b([a-z][A-Za-z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.other.member.belm"
            },
            "2": {
              "name": "punctuation.separator.key-value.belm"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.declaration.belm",
          "match": "\\b(app|port|database|system|public|entity|auth|type|alias)\\b"
        },
        {
          "name": "keyword.control.rule.belm",
          "match": "\\b(rule|when|authorize|action|create)\\b"
        },
        {
          "name": "keyword.other.auth.belm",
          "match": "\\b(user_entity|email_field|role_field|code_ttl_minutes|session_ttl_hours|email_transport|email_from|email_subject|sendmail_path|dev_expose_code)\\b"
        },
        {
          "name": "keyword.other.public.belm",
          "match": "\\b(dir|mount|spa_fallback)\\b"
        },
        {
          "name": "keyword.other.system.belm",
          "match": "\\b(request_logs_buffer|http_max_request_body_mb|auth_request_code_rate_limit_per_minute|auth_login_rate_limit_per_minute|sqlite_journal_mode|sqlite_synchronous|sqlite_foreign_keys|sqlite_busy_timeout_ms|sqlite_wal_autocheckpoint|sqlite_journal_size_limit_mb|sqlite_mmap_size_mb|sqlite_cache_size_kb)\\b"
        },
        {
          "name": "storage.modifier.belm",
          "match": "\\b(primary|auto|optional)\\b"
        },
        {
          "name": "keyword.operator.logical.belm",
          "match": "\\b(and|or|not)\\b"
        },
        {
          "name": "support.function.belm",
          "match": "\\b(contains|startsWith|endsWith|len|matches|isRole)\\b(?=\\s*\\()"
        },
        {
          "name": "variable.other.member.belm",
          "match": "\\binput\\.([a-z][A-Za-z0-9_]*)\\b"
        },
        {
          "name": "variable.language.belm",
          "match": "\\b(input|auth_authenticated|auth_email|auth_user_id|auth_role)\\b"
        },
        {
          "name": "support.constant.action.belm",
          "match": "\\b(list|get|create|update|delete)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.belm",
          "match": "\\b(Int|String|Bool|Float)\\b"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "name": "constant.language.boolean.belm",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.belm",
          "match": "\\bnull\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.belm",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.belm",
          "match": "==|!=|>=|<=|>|<"
        },
        {
          "name": "keyword.operator.arithmetic.belm",
          "match": "\\+|-|\\*|/"
        },
        {
          "name": "keyword.operator.assignment.belm",
          "match": "="
        },
        {
          "name": "keyword.operator.arrow.belm",
          "match": "->"
        },
        {
          "name": "punctuation.section.block.begin.belm",
          "match": "\\{"
        },
        {
          "name": "punctuation.section.block.end.belm",
          "match": "\\}"
        },
        {
          "name": "punctuation.section.parens.begin.belm",
          "match": "\\("
        },
        {
          "name": "punctuation.section.parens.end.belm",
          "match": "\\)"
        },
        {
          "name": "punctuation.section.brackets.begin.belm",
          "match": "\\["
        },
        {
          "name": "punctuation.section.brackets.end.belm",
          "match": "\\]"
        },
        {
          "name": "punctuation.separator.comma.belm",
          "match": ","
        }
      ]
    }
  }
}
