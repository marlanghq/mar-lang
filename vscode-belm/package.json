{
  "name": "belm-language-support",
  "displayName": "Belm Language Support",
  "description": "Syntax highlighting, snippets, and LSP support for modern Belm (.belm) files.",
  "version": "0.1.1",
  "publisher": "belm-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/marcio/belm.git"
  },
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "onLanguage:belm"
  ],
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "belm",
        "aliases": [
          "Belm",
          "belm"
        ],
        "extensions": [
          ".belm"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "belm",
        "scopeName": "source.belm",
        "path": "./syntaxes/belm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "belm",
        "path": "./snippets/belm.json"
      }
    ],
    "configuration": {
      "title": "Belm",
      "properties": {
        "belm.languageServer.path": {
          "type": "string",
          "default": "belm",
          "description": "Path or command used to start the Belm Language Server via `<command> lsp`."
        }
      }
    }
  }
}
