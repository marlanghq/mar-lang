# Generated by `mar fly init`. Hand-edits welcome — re-running init
# will detect non-empty `deploy/fly/` and ask before overwriting.
#
# This image runs the Linux executable produced by `mar build
# --target linux-amd64`. The binary is self-contained: it embeds
# every .mar source file and mar.json, and the SQLite driver is
# statically linked. No mar toolchain is needed inside the image.

FROM debian:bookworm-slim

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# `mar build --target linux-amd64 --out deploy/fly/dist` writes the
# binary at deploy/fly/dist/{{.AppName}}. The `mar fly deploy`
# helper runs that build for you; or do it manually before
# `fly deploy`.
COPY dist/{{.AppName}} /app/{{.AppName}}

EXPOSE {{.Port}}
CMD ["/app/{{.AppName}}"]
