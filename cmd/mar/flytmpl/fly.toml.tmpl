# Generated by `mar fly init`. Customize freely — re-running init will
# detect non-empty `deploy/fly/` and ask before overwriting.
#
# Docs: https://fly.io/docs/reference/configuration/

app = "{{.AppName}}"
primary_region = "{{.Region}}"

[build]
  dockerfile = "Dockerfile"

# Persistent SQLite. The volume mounts at /data inside the container;
# MAR_DATABASE_PATH tells the runtime to open the DB from there. Both
# pieces are required — without the env var, the runtime falls back to
# the project's default `<name>.db` next to mar.json, which inside the
# container would land on ephemeral storage.
[env]
  MAR_DATABASE_PATH = "/data/{{.AppName}}.db"

[mounts]
  source = "{{.VolumeName}}"
  destination = "/data"

[http_service]
  internal_port = {{.Port}}
  force_https = true                # fly's edge terminates TLS for free
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0          # scale to zero when idle

[[vm]]
  size = "shared-cpu-1x"
  memory = "{{.Memory}}"
